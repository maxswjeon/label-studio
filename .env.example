# Copy to .env and fill in real values. Do NOT commit the filled-in .env.
# (docker-compose.yml reads these; see comments there for what each controls.)

# --- Local PostgreSQL container (services.postgres) ---
# Password for the local `labelstudio` DB user. Decoupled from DATABASE_* below.
LOCAL_DB_PASSWORD=

# --- App database connection (POSTGRE_* in compose) ---
# Point these at the local postgres service (host=postgres, name=label-studio,
# user=labelstudio, password=LOCAL_DB_PASSWORD) or at an external/RDS instance.
DATABASE_HOST=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=

# --- AWS credentials for S3 media storage + per-project Cloud Storage sync ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=
S3_FOLDER=

# --- Public URL (also used for CSRF_TRUSTED_ORIGINS) ---
LABEL_STUDIO_HOST=

# --- Optional: initial admin bootstrap (compose: LABEL_STUDIO_USERNAME/PASSWORD) ---
# LABEL_STUDIO_USERNAME=
# LABEL_STUDIO_PASSWORD=

# --- Optional: Redis password if your Redis requires auth (default: none) ---
# REDIS_PASSWORD=

# --- Tier-1 RBAC: email suffix marking a restricted external annotator ---
# (compose defaults to @ext.example.com if unset)
RBAC_RESTRICTED_EMAIL_SUFFIX=@ext.example.com

# ---------------------------------------------------------------------------
# NOTE: there is a SECOND env file at data/.env containing the Django SECRET_KEY.
# It is gitignored. Generate a fresh random key per deployment, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# and write it as:  SECRET_KEY=<value>
# ---------------------------------------------------------------------------
